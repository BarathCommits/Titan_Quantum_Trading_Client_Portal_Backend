								"exec": [
									"const response = pm.response.json();",
									"if (response.accessToken) {",
									"    pm.collectionVariables.set(\"accessToken\", response.accessToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"retail-investor@example.com\",\n    \"password\": \"SecurePassword123!\",\n    \"type\": \"INDIVIDUAL\"\n}",
							"options": {
